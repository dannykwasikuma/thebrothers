# Copy this file to .env.local and fill in your own values.
# Get these from your Supabase project: Settings -> API
#
# VITE_SUPABASE_URL looks like: https://abcdefghijk.supabase.co
# VITE_SUPABASE_ANON_KEY is the long "anon public" key (safe to expose in frontend code)

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
